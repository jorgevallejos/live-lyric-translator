{
  "name": "live-lyric-translator",
  "version": "0.1.0",
  "description": "Offline lyric/translation projection for macOS",
  "main": "electron/main.cjs",
  "author": "",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && node scripts/launch-electron.cjs\"",
    "dev:single": "cross-env VITE_SINGLE_SCREEN=1 npm run dev",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.6",
    "wait-on": "^7.2.0"
  }
}
